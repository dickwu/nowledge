# Safe local-development baseline. The binary does not load this file itself;
# see README.md for the shell command that exports it.
RAG_RUN_MODE=development
RAG_HOST=127.0.0.1
RAG_PORT=14242
RAG_TENANT_ID=local
RAG_STORE_BACKEND=memory
RAG_WRITE_CONSISTENCY=read_your_writes
RAG_PARSER_PROVIDER=builtin
RAG_LLM_PROVIDER=none
RAG_ANALYSIS_LLM_PROVIDER=none
RAG_HEALTH_LLM_ENABLED=false
RAG_HEALTH_REQUIRE_LLM=false
RAG_ALLOW_UNSAFE_UNAUTHENTICATED=true

# Do not use the development authentication setting above in production.
# Generate each production secret independently and keep it in a secret manager.
# RAG_INDEX_HASH_SECRET=<openssl rand -base64 48>
# RAG_BEARER_TOKEN=<random owner token, at least 8 characters>
# RAG_BEARER_TOKEN_SCOPE=owner
# RAG_BEARER_TOKEN_OWNER_USER_ID=<owner id>
# RAG_ADMIN_TOKEN=<independent random admin token, at least 8 characters>
# RAG_AUTH_USERS=<owner:token:role|role entries>

# Optional Meilisearch backend.
# RAG_STORE_BACKEND=meili
# RAG_MEILI_URL=http://127.0.0.1:7700
# RAG_MEILI_API_KEY=<secret if Meilisearch requires one>

# Optional MinerU parser.
# RAG_PARSER_PROVIDER=mineru
# RAG_MINERU_API_URL=http://127.0.0.1:8000

# Optional OpenAI-compatible LLM configuration.
# RAG_LLM_PROVIDER=openai
# RAG_LLM_MODEL=<model name>
# RAG_ANALYSIS_LLM_PROVIDER=openai
# RAG_ANALYSIS_LLM_MODEL=<model name>
# RAG_OPENAI_API_KEY=<secret>
